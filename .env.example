CONTAINER_NAME=seeed-lerobot
IMAGE_NAME=seanchangx/seeed-lerobot
# Do not set IMAGE_TAG here unless you want a single fixed tag for all profiles.
# Command Deck defaults tags by profile: cpu / gpu / humble / humble-gpu.
# IMAGE_TAG=

# CPU default: huggingface/lerobot-cpu:latest
# The GPU override file will switch this to huggingface/lerobot-gpu:latest
BASE_IMAGE=huggingface/lerobot-cpu:latest

# This project pins the Seeed fork to a known-good commit for reproducible builds.
# You can change this to another commit/tag/branch when needed.
SEEED_LEROBOT_REF=0f392484458cb5ebca0310c0c4c47390a31c80ed

# Host display forwarding for GUI apps (rviz/rqt), set if needed.
# DISPLAY=:0
